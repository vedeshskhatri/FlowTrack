# ─────────────────────────────────────────────────────────────────────────────
# FlowTrack Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to source control.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase — get these from https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# OpenRouter — free AI models, get a key at https://openrouter.ai
# Users can also provide their own key in Settings
OPENROUTER_API_KEY=sk-or-v1-...

# App — use http://localhost:3000 for local dev, your Vercel URL for production
NEXT_PUBLIC_APP_URL=http://localhost:3000
